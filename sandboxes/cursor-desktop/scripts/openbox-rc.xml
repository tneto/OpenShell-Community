<!--
  Minimal openbox configuration for cursor-desktop sandbox.
  Key behaviours:
    - Cursor is maximized + undecorated (not EWMH fullscreen — that often black-screens
      Electron under Xvfb + VNC while still filling the display).
    - OAuth / external browser windows (Chrome, Firefox, Chromium) use layer
      “above” and steal focus so they appear on top of Cursor.
    - Root (desktop) mouse bindings do not open a full Openbox menu.
-->
<openbox_config xmlns="http://openbox.org/3.4/rc">

  <resistance>
    <strength>10</strength>
    <screen_edge_strength>20</screen_edge_strength>
  </resistance>

  <focus>
    <!-- Raise and focus any window that is newly mapped (opened). -->
    <focusNew>yes</focusNew>
    <followMouse>no</followMouse>
    <focusLast>yes</focusLast>
    <underMouse>no</underMouse>
    <focusDelay>0</focusDelay>
    <raiseOnFocus>yes</raiseOnFocus>
  </focus>

  <placement>
    <policy>Smart</policy>
    <center>yes</center>
    <monitor>Primary</monitor>
  </placement>

  <theme>
    <name>Clearlooks</name>
    <titleLayout>NLC</titleLayout>
    <keepBorder>yes</keepBorder>
    <animateIconify>no</animateIconify>
  </theme>

  <desktops>
    <number>1</number>
    <firstdesk>1</firstdesk>
    <names><name>Desktop</name></names>
    <popupTime>0</popupTime>
  </desktops>

  <resize>
    <drawContents>yes</drawContents>
    <popupShow>Never</popupShow>
  </resize>

  <applications>
    <!-- Cursor: fill the screen without EWMH fullscreen (breaks paint on many Electron+VNC setups). -->
    <application name="cursor" class="Cursor">
      <maximized>yes</maximized>
      <decorations>no</decorations>
      <layer>normal</layer>
    </application>

    <!-- Google Chrome (Linux .deb): OAuth / sign-in must stack above Cursor. -->
    <application name="google-chrome" class="Google-chrome">
      <layer>above</layer>
      <focus>yes</focus>
    </application>

    <!-- Some Chrome builds report a stable-specific WM_CLASS. -->
    <application name="google-chrome-stable" class="Google-chrome-stable">
      <layer>above</layer>
      <focus>yes</focus>
    </application>

    <!-- Generic Chromium / Electron-based browser builds -->
    <application class="Chromium-browser" name="chromium-browser">
      <layer>above</layer>
      <focus>yes</focus>
    </application>

    <!-- Firefox (arm64 image / alternative browser). -->
    <application class="Firefox">
      <layer>above</layer>
      <focus>yes</focus>
    </application>
  </applications>

  <!-- Minimal keyboard bindings — keep Super+H to hide a window if needed -->
  <keyboard>
    <chainQuitKey>C-g</chainQuitKey>
    <keybind key="A-F4">
      <action name="Close"/>
    </keybind>
    <keybind key="A-Tab">
      <action name="NextWindow">
        <finalactions>
          <action name="Focus"/>
          <action name="Raise"/>
          <action name="Unshade"/>
        </finalactions>
      </action>
    </keybind>
  </keyboard>

  <mouse>
    <dragThreshold>1</dragThreshold>
    <doubleClickTime>200</doubleClickTime>
    <screenEdgeWarpTime>400</screenEdgeWarpTime>
    <screenEdgeWarpMouse>false</screenEdgeWarpMouse>
    <!-- No Openbox root menu — avoid “desktop environment” affordances in VNC. -->
    <context name="Root">
      <mousebind button="Left" action="Press">
        <action name="Focus"/>
      </mousebind>
      <mousebind button="Right" action="Press">
        <action name="Focus"/>
      </mousebind>
      <mousebind button="Middle" action="Press">
        <action name="Focus"/>
      </mousebind>
    </context>
    <context name="Frame">
      <mousebind button="A-Left" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
        <action name="Move"/>
      </mousebind>
    </context>
  </mouse>

</openbox_config>
